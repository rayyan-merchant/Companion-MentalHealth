APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/companion.db
REDIS_URL=redis://localhost:6379/0
SUPPORT_EMAIL=support@example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=
SESSION_DAYS=7
DELETED_CONVERSATION_RETENTION_DAYS=30
SECURITY_LOG_RETENTION_DAYS=90
PROVIDER_TIMEOUT_SECONDS=6
INSIGHT_CACHE_SECONDS=900
LOG_LEVEL=INFO

# External AI is opt-in. User text may be sent to configured providers.
ENABLE_LLM=false
GROQ_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
GEMINI_LLM_MODEL=gemini-2.0-flash

# Semantic extraction and vector memory are separately opt-in.
ENABLE_EMBEDDINGS=false
ENABLE_VECTOR_MEMORY=false
PREWARM_CONCEPT_EMBEDDINGS=false
HF_TOKEN=
JINA_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
